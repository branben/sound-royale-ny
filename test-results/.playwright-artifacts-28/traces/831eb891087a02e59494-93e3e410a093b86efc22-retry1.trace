ors, gradients, fonts, etc should be defined here. \nAll colors MUST be HSL.\n*/\n/* CRT Scanline Effect */\n.crt-scanlines {\n  background: linear-gradient(\n    0deg,\n    transparent 50%,\n    rgba(0, 0, 0, 0.03) 50%\n  );\n  background-size: 100% 4px;\n  pointer-events: none;\n}\n/* Neon Glow Effects */\n.neon-glow {\n  box-shadow: 0 0 20px rgba(124, 58, 237, 0.4);\n}\n.neon-glow-strong {\n  box-shadow: 0 0 30px rgba(124, 58, 237, 0.6);\n}\n.neon-text {\n  text-shadow: 0 0 10px rgba(124, 58, 237, 0.5);\n}\n/* Crown Glow Animation */\n@keyframes crown-glow {\n  0%, 100% {\n    filter: drop-shadow(0 0 5px rgba(234, 179, 8, 0.5));\n  }\n  50% {\n    filter: drop-shadow(0 0 15px rgba(234, 179, 8, 0.9));\n  }\n}\n.crown-glow {\n  animation: crown-glow 2s ease-in-out infinite;\n}\n/* Card Entrance Animation */\n@keyframes card-enter {\n  0% {\n    opacity: 0;\n    transform: translateY(20px) scale(0.95);\n  }\n  100% {\n    opacity: 1;\n    transform: translateY(0) scale(1);\n  }\n}\n.card-enter {\n  animation: card-enter 400ms cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n/* Stagger Animation for Lists */\n@keyframes stagger-enter {\n  0% {\n    opacity: 0;\n    transform: translateX(-10px);\n  }\n  100% {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n.stagger-enter {\n  animation: stagger-enter 300ms ease-out forwards;\n}\n/* Pulse Animation for Waiting State */\n@keyframes pulse-waiting {\n  0%, 100% {\n    opacity: 0.4;\n  }\n  50% {\n    opacity: 0.8;\n  }\n}\n.pulse-waiting {\n  animation: pulse-waiting 2s ease-in-out infinite;\n}\n/* Reduced Motion Support */\n@media (prefers-reduced-motion: reduce) {\n  .crown-glow,\n  .card-enter,\n  .stagger-enter,\n  .pulse-waiting {\n    animation: none;\n  }\n}\n.file\\:border-0::file-selector-button{\n  border-width: 0px;\n}\n.file\\:bg-transparent::file-selector-button{\n  background-color: transparent;\n}\n.file\\:text-sm::file-selector-button{\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n}\n.file\\:font-